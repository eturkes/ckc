{
  "name": "ckc",
  "owner": {
    "name": "ckc agents",
    "email": "agents@ckc.local"
  },
  "metadata": {
    "description": "Project-local LSP plugins for the CKC workspace, covering the formal-methods, data, and markup formats used across the project. Server binaries must be present on PATH; see plugin READMEs for install commands."
  },
  "plugins": [
    {
      "name": "yaml-lsp",
      "description": "YAML LSP via yaml-language-server (Red Hat)",
      "version": "1.0.0",
      "source": "./plugins/yaml-lsp",
      "category": "development",
      "strict": false,
      "lspServers": {
        "yaml": {
          "command": "yaml-language-server",
          "args": [
            "--stdio"
          ],
          "extensionToLanguage": {
            ".yaml": "yaml",
            ".yml": "yaml"
          }
        }
      }
    },
    {
      "name": "toml-lsp",
      "description": "TOML LSP via taplo",
      "version": "1.0.0",
      "source": "./plugins/toml-lsp",
      "category": "development",
      "strict": false,
      "lspServers": {
        "taplo": {
          "command": "taplo",
          "args": [
            "lsp",
            "stdio"
          ],
          "extensionToLanguage": {
            ".toml": "toml"
          }
        }
      }
    },
    {
      "name": "lean4-lsp",
      "description": "Lean 4 LSP via lake serve",
      "version": "1.0.0",
      "source": "./plugins/lean4-lsp",
      "category": "development",
      "strict": false,
      "lspServers": {
        "lean4": {
          "command": "lake",
          "args": [
            "serve"
          ],
          "extensionToLanguage": {
            ".lean": "lean4"
          }
        }
      }
    },
    {
      "name": "xml-lsp",
      "description": "XML LSP via Eclipse LemMinX; covers DMN, BPMN, SHACL-XML and generic XML/XSD",
      "version": "1.0.0",
      "source": "./plugins/xml-lsp",
      "category": "development",
      "strict": false,
      "lspServers": {
        "lemminx": {
          "command": "lemminx",
          "extensionToLanguage": {
            ".xml": "xml",
            ".xsd": "xml",
            ".dmn": "xml",
            ".bpmn": "xml"
          }
        }
      }
    },
    {
      "name": "alloy-lsp",
      "description": "Alloy 6 LSP via the `lsp` subcommand of org.alloytools.alloy.dist.jar",
      "version": "1.0.0",
      "source": "./plugins/alloy-lsp",
      "category": "development",
      "strict": false,
      "lspServers": {
        "alloy": {
          "command": "alloy-lsp",
          "extensionToLanguage": {
            ".als": "alloy"
          }
        }
      }
    },
    {
      "name": "dolmen-lsp",
      "description": "Dolmen LSP for SMT-LIB, TPTP, DIMACS, Zipperposition",
      "version": "1.0.0",
      "source": "./plugins/dolmen-lsp",
      "category": "development",
      "strict": false,
      "lspServers": {
        "dolmenls": {
          "command": "dolmen-lsp",
          "extensionToLanguage": {
            ".smt2": "smtlib",
            ".cnf": "dimacs",
            ".icnf": "dimacs",
            ".p": "tptp",
            ".tptp": "tptp",
            ".zf": "zf"
          }
        }
      }
    },
    {
      "name": "egglog-lsp",
      "description": "egglog LSP via hatoo/egglog-language-server",
      "version": "1.0.0",
      "source": "./plugins/egglog-lsp",
      "category": "development",
      "strict": false,
      "lspServers": {
        "egglog": {
          "command": "egglog-lsp",
          "extensionToLanguage": {
            ".egg": "egglog"
          }
        }
      }
    }
  ]
}
