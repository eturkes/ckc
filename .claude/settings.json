{
  "permissions": {
    "deny": [
      "Read(./.git/**)",
      "Read(./LICENSE)",
      "Read(./Cargo.lock)",
      "Read(./target/**)",
      "Read(./runs/**)",
      "Read(./corpus/raw/**)",
      "Read(./corpus/test_sources/**)",
      "Read(./.serena/cache/**)",
      "Read(./.serena/memories/**)",
      "Read(./.serena/project.local.yml)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "WebSearch",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/deny-websearch.sh"
          }
        ]
      }
    ]
  }
}
