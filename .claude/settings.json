{
  "permissions": {
    "deny": [
      "Read(./.git/**)",
      "Read(./LICENSE)",
      "Read(./Cargo.lock)",
      "Read(./target/**)",
      "Read(./runs/**)",
      "Read(./corpus/raw/**)",
      "Read(./corpus/fixtures/**)",
      "Read(./.serena/cache/**)",
      "Read(./.serena/memories/**)",
      "Read(./.serena/project.local.yml)",
      "Read(./.claude/marketplace/**)",
      "Read(./.agent/lexgate.d/**)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.agent/lexgate.sh hook"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "json-lsp@ckc-lsps": true,
    "yaml-lsp@ckc-lsps": true,
    "markdown-lsp@ckc-lsps": true,
    "toml-lsp@ckc-lsps": true,
    "html-lsp@ckc-lsps": true,
    "xml-lsp@ckc-lsps": true,
    "lean4-lsp@ckc-lsps": true,
    "alloy-lsp@ckc-lsps": true,
    "dolmen-lsp@ckc-lsps": true,
    "egglog-lsp@ckc-lsps": true
  },
  "extraKnownMarketplaces": {
    "ckc-lsps": {
      "source": {
        "source": "directory",
        "path": ".claude/marketplace"
      }
    }
  }
}
