# Headroom introduces .serena/: project.yml is the tracked LSP config, while
# cache/, project.local.yml, and memories/ are ignored. See CLAUDE.md.
.serena/cache/
.serena/project.local.yml
.serena/memories/

# Rust build output (Cargo.lock is committed, not ignored)
target/

# Python (uv.lock is committed, not ignored)
__pycache__/
*.py[cod]
.venv/
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Generated corpus inputs and run outputs (SPEC §3); commit only when license-safe
/corpus/raw/
/runs/
