+/// One route's §9 failure-taxonomy summary row: count maps keyed by the §6
+/// verifier categories (over the route's solver-executed queries) and by the
+/// §7.4 diagnostic codes (over the route's diagnostics, the M2 model-route
+/// codes included). Both maps carry observed entries only (counts positive);
+/// the report-level `failure_taxonomy` lists one row per route in the
+/// experiment pipeline-set order, mirroring the metrics member.
+#[derive(Debug, Clone, PartialEq, Eq)]
+pub struct RouteTaxonomy {
+    pub categories: Vec<(Id, u64)>,
+    pub codes: Vec<(Id, u64)>,
+    pub pipeline_id: Id,
+}
+
+impl Canonical for RouteTaxonomy {
+    fn emit_canonical(&self, out: &mut Vec<u8>) -> Result<(), CanonError> {
+        let mut obj = ObjectEmitter::new();
+        obj.member("categories", |b| emit_u64_map(b, &self.categories))?;
+        obj.member("codes", |b| emit_u64_map(b, &self.codes))?;
+        obj.member("pipeline_id", |b| self.pipeline_id.emit_canonical(b))?;
+        obj.finish(out)
+    }
+}
+
+impl CanonRead for RouteTaxonomy {
+    fn read(r: &mut Reader<'_>) -> Result<Self, CanonReadError> {
+        let mut obj = ObjectReader::open(r)?;
+        let categories = obj.member("categories", read_u64_map)?;
+        let codes = obj.member("codes", read_u64_map)?;
+        let pipeline_id = obj.member("pipeline_id", Id::read)?;
+        obj.close()?;
+        Ok(RouteTaxonomy {
+            categories,
+            codes,
+            pipeline_id,
+        })
+    }
+}
+
