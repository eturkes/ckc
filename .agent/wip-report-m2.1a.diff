+        let pipeline_id = obj.member("pipeline_id", Id::read)?;
+        let rows = obj.member("rows", read_set::<MetricRow>)?;
+        obj.close()?;
+        Ok(RouteMetrics {
+            pipeline_id,
+            rows,
