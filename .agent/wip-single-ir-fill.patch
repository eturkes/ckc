+    #[test]
+    fn single_ir_fill_reproduces_m1_bundles() {
+        let root = repo_root();
+        let lexicon = single_ir_lexicon();
+        let resolved = single_ir_resolved();
+        let store = CassetteStore::new(root.join("crates/ckc-cli/tests/fixtures"));
