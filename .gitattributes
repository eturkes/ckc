# Byte-pinned text artifacts: their sha256 is pinned (ckc-smt
# grammar_hash_is_pinned, ckc-cli schema_hash_is_pinned, and each
# `registry/prompts.yaml` entry's `template_hash`, checked by `ckc registry
# check`), and the grammar's `<nl>` terminal is a literal LF the emitter
# matches. Force LF so the pins and the recognizer hold on any checkout.
schemas/smt_query.grammar text eol=lf
schemas/clinical_ir.schema.json text eol=lf
registry/prompts/*.txt text eol=lf

# Salvage patches (.agent/wip-<unit>.patch): unified diffs whose blank-context lines are a single
# space by format → `git show --check` would flag them. Skip the whitespace check (the patch still
# applies; stripping those markers would corrupt it).
.agent/*.patch -whitespace
