{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "QrelJudgment",
  "description": "A single relevance judgment for retrieval evaluation (qrel entry).",
  "type": "object",
  "properties": {
    "query_id": {
      "$ref": "#/$defs/QueryId"
    },
    "relevance": {
      "type": "integer",
      "format": "uint32",
      "minimum": 0
    },
    "span_id": {
      "$ref": "#/$defs/SpanId"
    }
  },
  "required": [
    "query_id",
    "span_id",
    "relevance"
  ],
  "$defs": {
    "QueryId": {
      "description": "Primary key for `RetrievalQuery`.",
      "type": "string"
    },
    "SpanId": {
      "description": "Primary key for `SourceSpan`.",
      "type": "string"
    }
  }
}
