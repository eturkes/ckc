{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EvidenceAtom",
  "description": "Single evidence atom with effect estimate and source grounding (SPEC 10).",
  "type": "object",
  "properties": {
    "certainty": {
      "$ref": "#/$defs/EvidenceCertainty"
    },
    "confidence_interval": {
      "anyOf": [
        {
          "$ref": "#/$defs/ConfidenceInterval"
        },
        {
          "type": "null"
        }
      ]
    },
    "effect_measure": {
      "type": [
        "string",
        "null"
      ]
    },
    "evidence_type": {
      "type": "string"
    },
    "outcome_importance": {
      "type": [
        "string",
        "null"
      ]
    },
    "pico_ref": {
      "anyOf": [
        {
          "$ref": "#/$defs/CqId"
        },
        {
          "type": "null"
        }
      ]
    },
    "source_span_ids": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/SpanId"
      }
    },
    "table_cell_refs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/TableCellRef"
      }
    },
    "unit": {
      "type": [
        "string",
        "null"
      ]
    },
    "value": {
      "type": [
        "number",
        "null"
      ],
      "format": "double"
    }
  },
  "required": [
    "evidence_type",
    "source_span_ids",
    "certainty",
    "table_cell_refs"
  ],
  "$defs": {
    "ConfidenceInterval": {
      "description": "Numeric confidence interval bounds for effect estimates.",
      "type": "object",
      "properties": {
        "lower": {
          "type": "number",
          "format": "double"
        },
        "upper": {
          "type": "number",
          "format": "double"
        }
      },
      "required": [
        "lower",
        "upper"
      ]
    },
    "CqId": {
      "description": "Clinical question identifier.",
      "type": "string"
    },
    "EvidenceCertainty": {
      "description": "GRADE evidence certainty (SPEC 10 Norm, EtDFrame, EvidenceAtom).\nVariant order matches certainty level: VeryLow < Low < Moderate < High.",
      "type": "string",
      "enum": [
        "very_low",
        "low",
        "moderate",
        "high"
      ]
    },
    "ExtractedTableId": {
      "description": "Primary key for `ExtractedTable`.",
      "type": "string"
    },
    "SpanId": {
      "description": "Primary key for `SourceSpan`.",
      "type": "string"
    },
    "TableCellRef": {
      "description": "Reference to a cell within an extracted table.",
      "type": "object",
      "properties": {
        "col": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "row": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "table_id": {
          "$ref": "#/$defs/ExtractedTableId"
        }
      },
      "required": [
        "table_id",
        "row",
        "col"
      ]
    }
  }
}
