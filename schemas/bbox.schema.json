{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BBox",
  "description": "Page bounding box (PDF coordinates).",
  "type": "object",
  "properties": {
    "height": {
      "type": "number",
      "format": "double"
    },
    "width": {
      "type": "number",
      "format": "double"
    },
    "x": {
      "type": "number",
      "format": "double"
    },
    "y": {
      "type": "number",
      "format": "double"
    }
  },
  "required": [
    "x",
    "y",
    "width",
    "height"
  ]
}
