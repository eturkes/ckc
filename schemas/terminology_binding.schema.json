{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TerminologyBinding",
  "description": "Binding from a concept to an external terminology system (SPEC 6.2, 10).",
  "type": "object",
  "properties": {
    "code": {
      "type": [
        "string",
        "null"
      ]
    },
    "confidence": {
      "type": "number",
      "format": "double"
    },
    "label": {
      "type": "string"
    },
    "license_status": {
      "type": "string"
    },
    "mapping_relation": {
      "type": "string"
    },
    "provenance": {
      "type": "string"
    },
    "status": {
      "$ref": "#/$defs/BindingStatus"
    },
    "system": {
      "type": "string"
    },
    "valid_from": {
      "type": [
        "string",
        "null"
      ]
    },
    "valid_to": {
      "type": [
        "string",
        "null"
      ]
    },
    "version": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "required": [
    "system",
    "label",
    "status",
    "mapping_relation",
    "provenance",
    "confidence",
    "license_status"
  ],
  "$defs": {
    "BindingStatus": {
      "description": "Terminology binding status (SPEC 6.2).",
      "type": "string",
      "enum": [
        "exact",
        "broad",
        "narrow",
        "related",
        "unmapped",
        "ambiguous",
        "deprecated",
        "incoherent"
      ]
    }
  }
}
