{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ClinicalClaim",
  "description": "Top-level clinical claim aggregating evidence, rules, and glosses (SPEC 10).",
  "type": "object",
  "properties": {
    "claim_id": {
      "$ref": "#/$defs/ClaimId"
    },
    "claim_type": {
      "type": "string"
    },
    "decision_table_ids": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/DecisionTableId"
      }
    },
    "etd": {
      "anyOf": [
        {
          "$ref": "#/$defs/EtDFrame"
        },
        {
          "type": "null"
        }
      ]
    },
    "evidence_atoms": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/EvidenceAtom"
      }
    },
    "gloss_en": {
      "type": "string"
    },
    "gloss_ja": {
      "type": "string"
    },
    "pico": {
      "anyOf": [
        {
          "$ref": "#/$defs/PICOFrame"
        },
        {
          "type": "null"
        }
      ]
    },
    "profiles": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/SemanticProfile"
      }
    },
    "rule_ids": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/RuleId"
      }
    },
    "source_span_ids": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/SpanId"
      }
    },
    "status": {
      "type": "string"
    },
    "workflow_fragment_ids": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/WorkflowId"
      }
    }
  },
  "required": [
    "claim_id",
    "claim_type",
    "profiles",
    "source_span_ids",
    "evidence_atoms",
    "rule_ids",
    "decision_table_ids",
    "workflow_fragment_ids",
    "gloss_ja",
    "gloss_en",
    "status"
  ],
  "$defs": {
    "ClaimId": {
      "description": "Primary key for `ClinicalClaim`.",
      "type": "string"
    },
    "ConfidenceInterval": {
      "description": "Numeric confidence interval bounds for effect estimates.",
      "type": "object",
      "properties": {
        "lower": {
          "type": "number",
          "format": "double"
        },
        "upper": {
          "type": "number",
          "format": "double"
        }
      },
      "required": [
        "lower",
        "upper"
      ]
    },
    "CqId": {
      "description": "Clinical question identifier.",
      "type": "string"
    },
    "DecisionTableId": {
      "description": "Primary key for `DecisionTable`.",
      "type": "string"
    },
    "EtDFrame": {
      "description": "Evidence-to-Decision frame with GRADE dimensions (SPEC 10).",
      "type": "object",
      "properties": {
        "acceptability": {
          "type": "string"
        },
        "benefits": {
          "type": "string"
        },
        "certainty": {
          "$ref": "#/$defs/EvidenceCertainty"
        },
        "equity": {
          "type": "string"
        },
        "feasibility": {
          "type": "string"
        },
        "harms": {
          "type": "string"
        },
        "recommendation_direction": {
          "$ref": "#/$defs/RecommendationDirection"
        },
        "recommendation_strength": {
          "$ref": "#/$defs/RecommendationStrength"
        },
        "resources": {
          "type": "string"
        },
        "source_span_ids": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/SpanId"
          }
        },
        "values": {
          "type": "string"
        }
      },
      "required": [
        "benefits",
        "harms",
        "certainty",
        "values",
        "resources",
        "equity",
        "acceptability",
        "feasibility",
        "recommendation_direction",
        "recommendation_strength",
        "source_span_ids"
      ]
    },
    "EvidenceAtom": {
      "description": "Single evidence atom with effect estimate and source grounding (SPEC 10).",
      "type": "object",
      "properties": {
        "certainty": {
          "$ref": "#/$defs/EvidenceCertainty"
        },
        "confidence_interval": {
          "anyOf": [
            {
              "$ref": "#/$defs/ConfidenceInterval"
            },
            {
              "type": "null"
            }
          ]
        },
        "effect_measure": {
          "type": [
            "string",
            "null"
          ]
        },
        "evidence_type": {
          "type": "string"
        },
        "outcome_importance": {
          "type": [
            "string",
            "null"
          ]
        },
        "pico_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/CqId"
            },
            {
              "type": "null"
            }
          ]
        },
        "source_span_ids": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/SpanId"
          }
        },
        "table_cell_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/TableCellRef"
          }
        },
        "unit": {
          "type": [
            "string",
            "null"
          ]
        },
        "value": {
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        }
      },
      "required": [
        "evidence_type",
        "source_span_ids",
        "certainty",
        "table_cell_refs"
      ]
    },
    "EvidenceCertainty": {
      "description": "GRADE evidence certainty (SPEC 10 Norm, EtDFrame, EvidenceAtom).\nVariant order matches certainty level: VeryLow < Low < Moderate < High.",
      "type": "string",
      "enum": [
        "very_low",
        "low",
        "moderate",
        "high"
      ]
    },
    "ExtractedTableId": {
      "description": "Primary key for `ExtractedTable`.",
      "type": "string"
    },
    "PICOFrame": {
      "description": "PICO frame for clinical question segmentation (SPEC 10).",
      "type": "object",
      "properties": {
        "comparator": {
          "type": "string"
        },
        "cq_id": {
          "anyOf": [
            {
              "$ref": "#/$defs/CqId"
            },
            {
              "type": "null"
            }
          ]
        },
        "exclusions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "intervention": {
          "type": "string"
        },
        "outcomes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "population": {
          "type": "string"
        },
        "scope": {
          "type": "string"
        },
        "source_span_ids": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/SpanId"
          }
        }
      },
      "required": [
        "population",
        "intervention",
        "comparator",
        "outcomes",
        "scope",
        "exclusions",
        "source_span_ids"
      ]
    },
    "RecommendationDirection": {
      "description": "Recommendation direction (SPEC 10 EtDFrame, Norm).",
      "type": "string",
      "enum": [
        "for",
        "against"
      ]
    },
    "RecommendationStrength": {
      "description": "GRADE recommendation strength (SPEC 10 Norm).",
      "type": "string",
      "enum": [
        "strong",
        "weak",
        "conditional"
      ]
    },
    "RuleId": {
      "description": "Primary key for `Rule`.",
      "type": "string"
    },
    "SemanticProfile": {
      "description": "CKC semantic profile (SPEC 9). Every CKC object declares which profiles\napply, determining allowed syntax, validators, compiler targets, and\ncertificate requirements.",
      "type": "string",
      "enum": [
        "CKC-Text",
        "CKC-Term",
        "CKC-Evidence",
        "CKC-Classical",
        "CKC-Norm",
        "CKC-Defeasible",
        "CKC-Para",
        "CKC-Temporal",
        "CKC-Event",
        "CKC-Quant",
        "CKC-Decision",
        "CKC-Workflow",
        "CKC-Interop",
        "CKC-Prob",
        "CKC-Cert",
        "CKC-Audit"
      ]
    },
    "SpanId": {
      "description": "Primary key for `SourceSpan`.",
      "type": "string"
    },
    "TableCellRef": {
      "description": "Reference to a cell within an extracted table.",
      "type": "object",
      "properties": {
        "col": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "row": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "table_id": {
          "$ref": "#/$defs/ExtractedTableId"
        }
      },
      "required": [
        "table_id",
        "row",
        "col"
      ]
    },
    "WorkflowId": {
      "description": "Primary key for `WorkflowFragment`.",
      "type": "string"
    }
  }
}
