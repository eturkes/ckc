{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DecisionTable",
  "description": "DMN-style decision table with hit policy and certificate linkage (SPEC 10).",
  "type": "object",
  "properties": {
    "certificate_ids": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/CertificateId"
      }
    },
    "dmn_export_id": {
      "anyOf": [
        {
          "$ref": "#/$defs/DmnExportId"
        },
        {
          "type": "null"
        }
      ]
    },
    "hit_policy": {
      "$ref": "#/$defs/HitPolicy"
    },
    "input_columns": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "output_columns": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "rows": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/DecisionRow"
      }
    },
    "source_table_id": {
      "anyOf": [
        {
          "$ref": "#/$defs/ExtractedTableId"
        },
        {
          "type": "null"
        }
      ]
    },
    "table_id": {
      "$ref": "#/$defs/DecisionTableId"
    }
  },
  "required": [
    "table_id",
    "hit_policy",
    "input_columns",
    "output_columns",
    "rows",
    "certificate_ids"
  ],
  "$defs": {
    "CertificateId": {
      "description": "Primary key for `Certificate`.",
      "type": "string"
    },
    "DecisionRow": {
      "description": "Decision table row with conditions, outputs, and source grounding (SPEC 10).",
      "type": "object",
      "properties": {
        "cell_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/TableCellRef"
          }
        },
        "conditions": {
          "type": "array",
          "items": true
        },
        "outputs": {
          "type": "array",
          "items": true
        },
        "priority": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "minimum": 0
        },
        "row_id": {
          "$ref": "#/$defs/DecisionRowId"
        },
        "source_span_ids": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/SpanId"
          }
        }
      },
      "required": [
        "row_id",
        "conditions",
        "outputs",
        "source_span_ids",
        "cell_refs"
      ]
    },
    "DecisionRowId": {
      "description": "Primary key for `DecisionRow`.",
      "type": "string"
    },
    "DecisionTableId": {
      "description": "Primary key for `DecisionTable`.",
      "type": "string"
    },
    "DmnExportId": {
      "description": "DMN export artifact identifier.",
      "type": "string"
    },
    "ExtractedTableId": {
      "description": "Primary key for `ExtractedTable`.",
      "type": "string"
    },
    "HitPolicy": {
      "description": "DMN hit policy for decision tables.",
      "type": "string",
      "enum": [
        "unique",
        "any",
        "priority",
        "first",
        "output_order",
        "rule_order",
        "collect"
      ]
    },
    "SpanId": {
      "description": "Primary key for `SourceSpan`.",
      "type": "string"
    },
    "TableCellRef": {
      "description": "Reference to a cell within an extracted table.",
      "type": "object",
      "properties": {
        "col": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "row": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "table_id": {
          "$ref": "#/$defs/ExtractedTableId"
        }
      },
      "required": [
        "table_id",
        "row",
        "col"
      ]
    }
  }
}
